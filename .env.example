# ============================================================
# SuperTutor AI — Environment Variables Reference
# Copy this file to .env.local and fill in real values
# NEVER commit .env.local to version control
# ============================================================

# ── Database ─────────────────────────────────────────────────
# PostgreSQL connection string (with PgBouncer for pooling)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?pgbouncer=true"
# Direct connection (used by Prisma migrations, bypasses PgBouncer)
DIRECT_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"

# ── Redis (Upstash) ──────────────────────────────────────────
UPSTASH_REDIS_REST_URL="https://REGION.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-token"

# ── Auth ─────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-nextauth-secret-min-32-chars"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth (https://console.cloud.google.com/)
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ── AI / LLM ─────────────────────────────────────────────────
# Groq (primary LLM — fast inference)
# https://console.groq.com/
GROQ_API_KEY="gsk_your-groq-api-key"

# Together AI (LLM fallback)
# https://api.together.xyz/
TOGETHER_AI_API_KEY="your-together-ai-api-key"

# ── Voice: Speech-to-Text ────────────────────────────────────
# OpenAI Whisper API
# https://platform.openai.com/
OPENAI_API_KEY="sk-your-openai-api-key"

# ── Voice: Text-to-Speech ────────────────────────────────────
# ElevenLabs TTS API
# https://elevenlabs.io/
ELEVENLABS_API_KEY="your-elevenlabs-api-key"
# Voice IDs from ElevenLabs voice library
ELEVENLABS_VOICE_ID_EN="21m00Tcm4TlvDq8ikWAM"   # Rachel (English, neutral)
ELEVENLABS_VOICE_ID_RU="your-russian-voice-id"
ELEVENLABS_VOICE_ID_UZ="your-uzbek-voice-id"
ELEVENLABS_DEFAULT_VOICE_ID="21m00Tcm4TlvDq8ikWAM"

# ── Avatar (HeyGen Streaming) ────────────────────────────────
# HeyGen API — server-side ONLY, never expose to client
# https://app.heygen.com/
HEYGEN_API_KEY="your-heygen-api-key"
# Avatar ID from HeyGen avatar library
HEYGEN_AVATAR_ID="your-avatar-id"

# ── App ──────────────────────────────────────────────────────
# Public URL — used for OAuth callbacks, API routes
# NEXT_PUBLIC_ prefix makes it available in browser
NEXT_PUBLIC_APP_URL="http://localhost:3000"
